{
    "$schema": "https://schema.khronos.org/vulkan/profiles-0.8.2-271.json#",
    "capabilities": {
        "baseline": {
            "extensions": {
                "VK_KHR_swapchain": 1,
                "VK_KHR_dynamic_rendering": 1,
                "VK_EXT_descriptor_indexing": 1
            },
            "features": {
                "VkPhysicalDeviceFeatures": {
                    "samplerAnisotropy": true,
                    "fillModeNonSolid": true,
                    "shaderInt64": false,
                    "multiDrawIndirect": false
                },
                "VkPhysicalDeviceVulkan12Features": {
                    "descriptorIndexing": true,
                    "shaderSampledImageArrayNonUniformIndexing": true,
                    "runtimeDescriptorArray": true,
                    "descriptorBindingPartiallyBound": true,
                    "descriptorBindingVariableDescriptorCount": false,
                    "timelineSemaphore": true,
                    "bufferDeviceAddress": false
                },
                "VkPhysicalDeviceVulkan13Features": {
                    "dynamicRendering": true,
                    "synchronization2": true
                }
            },
            "properties": {
                "VkPhysicalDeviceProperties": {
                    "limits": {
                        "maxPushConstantsSize": 128,
                        "maxDescriptorSetSamplers": 512,
                        "maxDescriptorSetSampledImages": 512,
                        "maxDescriptorSetStorageBuffers": 64,
                        "maxComputeWorkGroupInvocations": 256
                    }
                }
            }
        },
        "raytracing": {
            "extensions": {
                "VK_KHR_acceleration_structure": 1,
                "VK_KHR_ray_query": 1,
                "VK_KHR_deferred_host_operations": 1
            },
            "features": {
                "VkPhysicalDeviceAccelerationStructureFeaturesKHR": {
                    "accelerationStructure": true
                },
                "VkPhysicalDeviceRayQueryFeaturesKHR": {
                    "rayQuery": true
                }
            },
            "properties": {
                "VkPhysicalDeviceVulkan12Properties": {
                    "shaderGroupHandleAlignment": 32
                }
            }
        }
    },
    "profiles": {
        "VP_SIMPLEENGINE_BASELINE_1_0": {
            "version": 1,
            "api-version": "1.3.0",
            "label": "SimpleEngine Baseline Profile",
            "description": "Minimum required capabilities for all SimpleEngine scenes. Targets Maxwell+ (GTX 750 Ti) and up. Ray tracing is optional.",
            "history": [
                {
                    "revision": 1,
                    "date": "2026-03-15",
                    "author": "VulkanView Team",
                    "comment": "Initial profile definition"
                }
            ],
            "capabilities": ["baseline"]
        },
        "VP_SIMPLEENGINE_RAYTRACING_1_0": {
            "version": 1,
            "api-version": "1.3.0",
            "label": "SimpleEngine Ray Tracing Profile",
            "description": "Extended profile adding ray query shadow / reflection support. Requires Turing+ (RTX 20xx) or equivalent.",
            "history": [
                {
                    "revision": 1,
                    "date": "2026-03-15",
                    "author": "VulkanView Team",
                    "comment": "Initial ray tracing profile"
                }
            ],
            "capabilities": ["baseline", "raytracing"]
        }
    }
}
